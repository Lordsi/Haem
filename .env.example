# =============================================================================
# HEMA-Core HDMIS — Environment variables
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit `.env.local` or any file containing real secrets.
# On Render, set these as environment variables (not in the repo).
# =============================================================================

# ---- Supabase (public, safe to expose to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase service role (SERVER-ONLY — never expose to the client) ----
# Used only in trusted server contexts (Route Handlers / Server Actions).
SUPABASE_SERVICE_ROLE_KEY=

# ---- Field-level encryption (Option B: app-level AES-256-GCM) ----
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Use a SEPARATE key per environment (dev / staging / production).
# The current key version is what new rows are encrypted with; older
# versions are kept so previously-encrypted data can still be decrypted.
ENCRYPTION_KEY_CURRENT_VERSION=1
ENCRYPTION_KEY_V1=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
